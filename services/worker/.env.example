WORKER_NAME=bio-worker
WORKER_ID=worker-dev-1
WORKER_ENV=development
REDIS_URL=redis://localhost:6379/0
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
SIMULATION_QUEUE_NAME=jobs:simulation
DECOMPOSITION_QUEUE_NAME=jobs:decomposition
REPORT_QUEUE_NAME=jobs:report
WORKER_CONCURRENCY=2
HEARTBEAT_INTERVAL_SECONDS=15
QUEUE_BLOCK_TIMEOUT_SECONDS=5
JOB_LEASE_SECONDS=120
SIMULATION_TIMEOUT_SECONDS=1800
DECOMPOSITION_TIMEOUT_SECONDS=3600
REPORT_TIMEOUT_SECONDS=600
MAX_SIMULATION_ATTEMPTS=3
MAX_DECOMPOSITION_ATTEMPTS=3
MAX_REPORT_ATTEMPTS=5
OBJECT_STORAGE_BUCKET=bio-lab-dev
ARTIFACT_STORAGE_ROOT=.data/artifacts
SIMULATION_ENGINE_COMMAND=python3 -m soil_engine.cli
SIMULATION_ENGINE_PYTHONPATH=services/simulation-engine
WORKER_OPTIONAL_WHEN_REDIS_UNAVAILABLE=false
