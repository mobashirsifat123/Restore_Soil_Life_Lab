# Core API
API_NAME=Bio Soil API
API_VERSION=0.1.0
API_ENV=production
API_V1_PREFIX=/api/v1
API_PORT=8000
API_DEBUG=false

# Authentication / sessions
DEBUG_AUTH_ENABLED=false
AUTH_SESSION_COOKIE_NAME=bio_session
AUTH_SESSION_TTL_HOURS=168
AUTH_SESSION_SECURE_COOKIE=true
FRONTEND_URL=https://your-web-domain.com
ADMIN_USER_EMAILS=["admin@your-domain.com"]

# Database / cache
DATABASE_URL=postgresql+psycopg://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
DATABASE_ECHO=false
REDIS_URL=redis://<user>:<password>@<host>:6379/0

# Observability
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
ALLOWED_ORIGINS=["https://your-web-domain.com"]

# Email delivery
# Required in production to deliver forgot-password emails.
SMTP_HOST=smtp.your-provider.com
SMTP_PORT=587
SMTP_USERNAME=<your-smtp-username>
SMTP_PASSWORD=<your-smtp-password>
SMTP_FROM_EMAIL=noreply@your-domain.com
SMTP_STARTTLS=true

# Supabase
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<your-supabase-service-role-key>
SUPABASE_STORAGE_BUCKET=site-media

# LLM providers
DEEPSEEK_API_KEY=<your-deepseek-api-key>
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat
# Optional legacy provider support
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
SIMULATION_QUEUE_NAME=jobs:simulation
SIMULATION_ENGINE_NAME=soil-engine
SIMULATION_ENGINE_VERSION=0.1.0
SIMULATION_INPUT_SCHEMA_VERSION=1.0.0
RUN_INLINE_FALLBACK_ENABLED=false
